---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`flex items-center gap-2.5 ${className}`}>
  <svg width="34" height="34" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <rect width="48" height="48" rx="12" fill="#2563eb"></rect>
    <path d="M13 25.5 L20.5 33 L35 17" stroke="white" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
  <span class="text-xl font-bold tracking-tight text-slate-900">Bid<span class="text-blue-600">Wise</span></span>
</div>
