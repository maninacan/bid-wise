---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';

// The client app lives on a separate host in every environment.
// Priority: explicit PUBLIC_APP_URL build env → the client's local dev server
// (when running `astro dev`) → the production client.
const APP_URL =
  import.meta.env.PUBLIC_APP_URL ??
  (import.meta.env.DEV ? 'http://localhost:4200' : 'https://app.bidwise.builders');
const SIGN_IN = APP_URL;
const SIGN_UP = `${APP_URL}/?mode=signup`;

const features = [
  {
    title: 'AI takeoffs from your plans',
    body: 'Upload a house plan PDF and Bid Wise reads it — returning a structured takeoff broken down by trade, with materials and labor separated.',
    icon: 'M9 13.5 11.5 16 15.5 10.5 M7 3h7l5 5v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z',
  },
  {
    title: 'Pricing dialed to your market',
    body: 'Get material and labor prices tuned to your area, with per-line overrides so every bid reflects the numbers you actually charge.',
    icon: 'M12 1v22 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6',
  },
  {
    title: 'Professional bids in one click',
    body: 'Generate a clean, branded bid PDF with materials and labor subtotals, then email or text it to your client straight from Bid Wise.',
    icon: 'M4 4h16v12H5.2L4 17.2V4Z M8 9h8 M8 12h5',
  },
  {
    title: 'Subcontractors, handled',
    body: 'Invite subs to price their scope, collect their numbers, and approve their bids — all rolled into your master estimate.',
    icon: 'M16 20v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2 M9 10a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z M22 20v-2a4 4 0 0 0-3-3.9 M17 3.1a4 4 0 0 1 0 7.8',
  },
];

const steps = [
  { n: '1', title: 'Upload the plan', body: 'Drop in a house plan PDF — no manual measuring or spreadsheets.' },
  { n: '2', title: 'Review the takeoff', body: 'Bid Wise drafts a free trade-by-trade takeoff of materials and quantities for every trade. Tweak anything.' },
  { n: '3', title: 'Unlock pricing & send', body: 'Price the job for $0.05/sq ft of the plan (min $15), then export a polished bid PDF and deliver it by email or text in seconds.' },
];
---

<Layout>
  <!-- Header -->
  <header class="sticky top-0 z-20 border-b border-slate-100 bg-white/85 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" aria-label="Bid Wise home"><Logo /></a>
      <nav class="flex items-center gap-2 sm:gap-3">
        <a
          href={SIGN_IN}
          class="rounded-lg px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100"
        >Sign in</a>
        <a
          href={SIGN_UP}
          class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700"
        >Sign up</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="pointer-events-none absolute inset-x-0 -top-40 -z-10 mx-auto h-[500px] max-w-4xl rounded-full bg-blue-100/50 blur-3xl"></div>
      <div class="mx-auto max-w-6xl px-6 pt-20 pb-16 text-center sm:pt-28 sm:pb-24">
        <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">
          Estimating, minus the busywork
        </span>
        <h1 class="mx-auto mt-6 max-w-3xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl">
          Turn house plans into accurate bids in <span class="text-blue-600">minutes</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
          Bid Wise reads your plans, drafts a trade-by-trade takeoff, prices it to your market, and hands you a client-ready bid — so you can quote more work in less time.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={SIGN_UP}
            class="w-full rounded-xl bg-blue-600 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-blue-700 sm:w-auto"
          >Get a free takeoff</a>
          <a
            href={SIGN_IN}
            class="w-full rounded-xl border border-slate-300 bg-white px-7 py-3.5 text-base font-semibold text-slate-700 transition hover:bg-slate-50 sm:w-auto"
          >Sign in</a>
        </div>
        <p class="mt-4 text-sm text-slate-500">No card required · Takeoffs are free — pricing a bid costs $0.05/sq ft (min $15)</p>
      </div>
    </section>

    <!-- Features -->
    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <div class="grid gap-6 sm:grid-cols-2">
        {features.map((f) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-7 transition hover:border-blue-200 hover:shadow-sm">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon}></path>
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold text-slate-900">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="border-y border-slate-100 bg-slate-50">
      <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
        <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900">From plan to bid in three steps</h2>
        <div class="mt-12 grid gap-8 sm:grid-cols-3">
          {steps.map((s) => (
            <div class="text-center">
              <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-lg font-bold text-white">{s.n}</div>
              <h3 class="mt-5 text-lg font-semibold text-slate-900">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="mx-auto max-w-6xl px-6 py-20">
      <div class="overflow-hidden rounded-3xl bg-blue-600 px-8 py-14 text-center sm:px-16">
        <h2 class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Win the next job with a faster, sharper bid
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-blue-100">
          Create your account and turn your first plan into a bid today.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={SIGN_UP}
            class="w-full rounded-xl bg-white px-7 py-3.5 text-base font-semibold text-blue-700 shadow-sm transition hover:bg-blue-50 sm:w-auto"
          >Get started</a>
          <a
            href={SIGN_IN}
            class="w-full rounded-xl border border-blue-400/60 px-7 py-3.5 text-base font-semibold text-white transition hover:bg-blue-500 sm:w-auto"
          >Sign in</a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-slate-100">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-10 sm:flex-row">
      <Logo />
      <div class="flex items-center gap-6 text-sm text-slate-500">
        <a href={SIGN_IN} class="transition hover:text-slate-900">Sign in</a>
        <a href={SIGN_UP} class="transition hover:text-slate-900">Sign up</a>
      </div>
      <p class="text-sm text-slate-400">© {new Date().getFullYear()} Bid Wise</p>
    </div>
  </footer>
</Layout>
