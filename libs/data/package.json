{
  "name": "@bid-wise/data",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "name": "data",
    "targets": {
      "codegen": {
        "executor": "nx:run-commands",
        "options": {
          "command": "graphql-codegen --config libs/data/codegen.ts",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  },
  "dependencies": {}
}
